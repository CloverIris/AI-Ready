<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AIRaedy.Desktop.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    BorderBrush="Transparent"
    Background="Transparent">

    <Grid Background="Transparent">
        <!--首页大标题-->
        <StackPanel HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Margin="60,0,0,280">
            <TextBlock Margin="0,0,0,0" 
                      Text="Version 0.1.0"
                      FontSize="20"
                      Foreground="White"/>
            <TextBlock 
                VerticalAlignment="Top"
                Height="60" 
                MinWidth="1000" 
                Text="AI-Ready · 智能就绪"
                FontSize="40"
                FontWeight="Bold"
                Foreground="White"
                Style="{ThemeResource TitleTextBlockStyle}"/>
            <TextBlock 
                Text="本地 AI 部署与云端算力管理"
                FontSize="22"
                Foreground="White"
                Opacity="0.9"/>
        </StackPanel>
           
        <!--左侧底部按钮组-->
        <StackPanel Margin="30" 
                   VerticalAlignment="Bottom" 
                   HorizontalAlignment="Left" 
                   Orientation="Vertical">
            <!-- 硬件信息显示 -->
            <TextBlock x:Name="HardwareInfoText"
                      Style="{ThemeResource CaptionTextBlockStyle}"
                      Foreground="White"
                      TextWrapping="Wrap"
                      Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="OpenLocalPage" 
                       Margin="0,0,15,0" 
                       CornerRadius="20" 
                       Width="200" 
                       Height="40" 
                       Foreground="White"
                       Click="OpenLocalPage_Click">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Margin="0,0,10,0" VerticalAlignment="Center" Glyph="&#xE70F;" />
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" Text="本地环境"/>
                    </StackPanel>
                </Button> 
            </StackPanel>
        </StackPanel>
        
        <!--右侧底部按钮组-->
        <StackPanel Margin="30" 
                   VerticalAlignment="Bottom" 
                   HorizontalAlignment="Right" 
                   Orientation="Horizontal">
            <StackPanel Grid.Row="1" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       Spacing="10">
                <Button x:Name="QuickStartButton"
                       Style="{StaticResource AccentButtonStyle}"
                       Click="QuickStartButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon x:Name="StartIcon" 
                                 Glyph="&#xE768;"/>
                        <TextBlock x:Name="QuickStartText" 
                                  Text="快速开始"/>
                    </StackPanel>
                </Button>
                
                <TextBlock x:Name="StatusText"
                          Foreground="White"
                          HorizontalAlignment="Center"/>
            </StackPanel>
            
            <Button x:Name="OpenCloudPage" 
                   CornerRadius="20" 
                   Width="120" 
                   Height="40"  
                   Foreground="White"
                   Click="OpenCloudPage_Click">
                <StackPanel Orientation="Horizontal">
                    <FontIcon Margin="0,0,10,0" VerticalAlignment="Center" Glyph="&#xE753;" />
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" Text="云端"/>
                </StackPanel>
            </Button>
        </StackPanel>
        
        <!--右侧卡片展示组-->
        <StackPanel Margin="50" 
                   VerticalAlignment="Center"  
                   HorizontalAlignment="Right" 
                   Orientation="Vertical">
            <!--轮播图-->
            <StackPanel HorizontalAlignment="Right" Margin="0,0,20,-25">
                <Image Width="270" 
                       Height="200" 
                       Source="\picture\How-to-Use-DeepSeek-R1.jpg"/>
            </StackPanel>
            
            <!--资讯、公告、活动和教程-->
            <Border CornerRadius="10" 
                   Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}">
                <Pivot HorizontalAlignment="Right" 
                      Height="160" 
                      Width="300">
                    <PivotItem Header="资讯">
                        <TextBlock HorizontalAlignment="Stretch" 
                                  Margin="5" 
                                  TextWrapping="Wrap" 
                                  Text="AI-Ready 项目启动，致力于让每个人都能轻松部署和使用开源 AI。"/>
                    </PivotItem>
                    <PivotItem Header="公告">
                        <TextBlock Text="当前为早期预览版本，功能持续开发中。" />
                    </PivotItem>
                    <PivotItem Header="活动">
                        <TextBlock Text="参与开源贡献，共建 AI 生态。" />
                    </PivotItem>
                    <PivotItem Header="教程">
                        <TextBlock Text="查看文档了解如何使用 AI-Ready 部署您的第一个 AI 项目。" />
                    </PivotItem>
                </Pivot>
            </Border>
        </StackPanel>
    </Grid>
</Page>
