<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AIReady.Desktop.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <TextBlock Grid.Row="0"
                  Text="设置"
                  FontSize="28"
                  FontWeight="Bold"
                  Foreground="White"
                  Margin="0,0,0,20"/>

        <!-- 设置内容 -->
        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- 关于 -->
                <Border CornerRadius="8"
                       Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                       Padding="20"
                       Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="关于 AI-Ready"
                                  FontSize="18"
                                  FontWeight="SemiBold"
                                  Foreground="White"/>
                        <TextBlock Text="Version 0.1.0"
                                  Foreground="White"
                                  Opacity="0.8"
                                  Margin="0,8,0,0"/>
                        <TextBlock Text="开源 AI 部署管理工具"
                                  Foreground="White"
                                  Opacity="0.6"
                                  FontSize="12"
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 外观设置 -->
                <Border CornerRadius="8"
                       Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                       Padding="20">
                    <StackPanel>
                        <TextBlock Text="外观"
                                  FontSize="18"
                                  FontWeight="SemiBold"
                                  Foreground="White"/>
                        <ToggleSwitch Header="深色模式"
                                     IsOn="True"
                                     Margin="0,12,0,0"
                                     Foreground="White"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
