<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AIReady.Desktop.Pages.ApiDebuggerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    BorderBrush="Transparent"
    Background="Transparent">

    <Grid Background="Transparent" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE769;" FontSize="32" Foreground="White"/>
                <TextBlock Text="API 调试器"
                          FontSize="32"
                          FontWeight="Bold"
                          Foreground="White"/>
            </StackPanel>
            <TextBlock Text="本地 API 代理、调试、审计、过期提醒一站式管理"
                      FontSize="16"
                      Foreground="White"
                      Opacity="0.8"
                      Margin="0,5,0,0"/>
        </StackPanel>

        <!-- 工具栏 -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <Button x:Name="AddEndpointButton" Click="AddEndpointButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="添加 API 端点"/>
                    </StackPanel>
                </Button>
                <Button x:Name="RefreshAllButton" Click="RefreshAllButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="全部检测"/>
                    </StackPanel>
                </Button>
                <Button x:Name="ProxySettingsButton" Click="ProxySettingsButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE774;" FontSize="14"/>
                        <TextBlock Text="代理设置"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                <ToggleSwitch x:Name="ProxyServiceToggle"
                             Header="代理服务"
                             OffContent="已停止"
                             OnContent="运行中"
                             Toggled="ProxyServiceToggle_Toggled"/>
            </StackPanel>
        </Grid>

        <!-- 主内容区 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">
                <!-- 代理服务状态 -->
                <Border CornerRadius="{ThemeResource OverlayCornerRadius}"
                       Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                       BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                       BorderThickness="1"
                       Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                            <FontIcon x:Name="ProxyStatusIcon" Glyph="&#xE768;" FontSize="32" Foreground="{StaticResource SystemFillColorSuccessBrush}"/>
                            <StackPanel>
                                <TextBlock x:Name="ProxyStatusText" Text="代理服务运行中" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock x:Name="ProxyEndpointText" Text="http://192.168.1.100:8080" Opacity="0.7" Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                            <StackPanel>
                                <TextBlock Text="今日调用" Opacity="0.6" FontSize="12"/>
                                <TextBlock x:Name="TodayCallsText" Text="1,234" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="已连接设备" Opacity="0.6" FontSize="12"/>
                                <TextBlock x:Name="ConnectedDevicesText" Text="3" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 过期提醒 -->
                <InfoBar x:Name="ExpirationAlertBar"
                        IsOpen="False"
                        Severity="Warning"
                        Title="即将过期"
                        Message="有 2 个 API 将在 7 天内过期"
                        Margin="0,0,0,10">
                    <InfoBar.ActionButton>
                        <Button Content="查看详情" Click="ViewExpiringApis_Click"/>
                    </InfoBar.ActionButton>
                </InfoBar>

                <!-- API 端点列表 -->
                <TextBlock Text="API 端点" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                
                <GridView x:Name="EndpointGrid"
                         SelectionMode="None"
                         IsItemClickEnabled="True"
                         ItemClick="EndpointItem_Click">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border Width="280" 
                                   Height="180"
                                   CornerRadius="{ThemeResource OverlayCornerRadius}"
                                   Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                   BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                   BorderThickness="1">
                                <Border.Shadow>
                                    <ThemeShadow/>
                                </Border.Shadow>
                                <Grid Margin="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- 头部：名称和状态 -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <FontIcon Glyph="{Binding TypeIcon}" FontSize="24"/>
                                        <StackPanel Margin="12,0,0,0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding TypeDisplay}" FontSize="12" Opacity="0.6"/>
                                        </StackPanel>
                                        <FontIcon Glyph="{Binding StatusIcon}" 
                                                 FontSize="12" 
                                                 Margin="8,0,0,0"
                                                 Foreground="{Binding StatusColor}"/>
                                    </StackPanel>
                                    
                                    <!-- 中部：余额和延迟 -->
                                    <StackPanel Grid.Row="1" Margin="0,12,0,0" Spacing="8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="余额: " FontSize="12" Opacity="0.6"/>
                                            <TextBlock Text="{Binding BalanceDisplay}" FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="延迟: " FontSize="12" Opacity="0.6"/>
                                            <TextBlock Text="{Binding LatencyDisplay}" FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="过期: " FontSize="12" Opacity="0.6"/>
                                            <TextBlock Text="{Binding ExpirationDisplay}" FontSize="12">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding ExpirationColor}"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- 底部：操作按钮 -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                        <Button Content="测试" 
                                               FontSize="12" 
                                               Padding="8,4"
                                               Click="TestEndpoint_Click"/>
                                        <Button Content="编辑" 
                                               FontSize="12" 
                                               Padding="8,4"
                                               Click="EditEndpoint_Click"/>
                                        <ToggleSwitch IsOn="{Binding IsShared}" 
                                                     FontSize="10"
                                                     Click="ToggleShare_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <!-- 使用统计 -->
                <TextBlock Text="今日使用统计" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,20,0,0"/>
                
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0"
                           CornerRadius="{ThemeResource OverlayCornerRadius}"
                           Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           Padding="16">
                        <StackPanel>
                            <TextBlock Text="模型使用分布" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <ItemsControl x:Name="ModelUsageList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding ModelName}" Grid.Column="0" FontSize="13"/>
                                            <TextBlock Text="{Binding Percentage}" Grid.Column="1" FontSize="13" Opacity="0.7" Margin="0,0,8,0"/>
                                            <ProgressBar Value="{Binding PercentageValue}" Maximum="100" Grid.Column="2" Width="60"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="1"
                           CornerRadius="{ThemeResource OverlayCornerRadius}"
                           Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           Padding="16">
                        <StackPanel>
                            <TextBlock Text="费用预估" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBlock x:Name="EstimatedCostText" Text="$3.45" FontSize="36" FontWeight="Bold"/>
                            <TextBlock Text="基于今日调用量估算" FontSize="12" Opacity="0.6" Margin="0,4,0,0"/>
                            
                            <TextBlock Text="每小时趋势" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8"/>
                            <!-- 这里可以放一个简化的折线图 -->
                            <TextBlock Text="[趋势图表占位]" Opacity="0.5" HorizontalAlignment="Center" Margin="0,20"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 已连接设备 -->
                <TextBlock Text="已连接设备" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,20,0,0"/>
                
                <ListView x:Name="ConnectedDevicesList" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="{Binding DeviceIcon}" FontSize="24" Margin="0,0,12,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding IpAddress}" FontSize="12" Opacity="0.6"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding CurrentApi}" Opacity="0.7" Margin="0,0,20,0"/>
                                <Button Grid.Column="3" Content="断开" Click="DisconnectDevice_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
