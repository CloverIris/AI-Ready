<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AIReady.Desktop.Pages.McpMarketplacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    BorderBrush="Transparent"
    Background="Transparent">

    <Grid Background="Transparent" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页面标题和说明 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE774;" FontSize="32" Foreground="White"/>
                <TextBlock Text="MCP 市场"
                          FontSize="32"
                          FontWeight="Bold"
                          Foreground="White"/>
            </StackPanel>
            <TextBlock Text="Model Context Protocol (MCP) 服务器市场 - 连接 AI 与外部世界"
                      FontSize="16"
                      Foreground="White"
                      Opacity="0.8"
                      Margin="0,5,0,0"/>
            <HyperlinkButton Content="📖 数据来源: registry.modelcontextprotocol.io"
                           NavigateUri="https://registry.modelcontextprotocol.io"
                           Margin="0,5,0,0"
                           Foreground="White"/>
        </StackPanel>

        <!-- 搜索和工具栏 -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <AutoSuggestBox x:Name="McpSearchBox"
                           PlaceholderText="搜索 MCP Servers..."
                           QueryIcon="Find"
                           Height="40"
                           VerticalAlignment="Center"
                           QuerySubmitted="McpSearchBox_QuerySubmitted"/>
            
            <StackPanel Grid.Column="1" 
                       Orientation="Horizontal" 
                       Spacing="10"
                       Margin="20,0,0,0">
                <DropDownButton Content="传输方式">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="全部" Click="FilterTransport_Click" Tag=""/>
                            <MenuFlyoutItem Text="stdio" Click="FilterTransport_Click" Tag="stdio"/>
                            <MenuFlyoutItem Text="HTTP (SSE)" Click="FilterTransport_Click" Tag="sse"/>
                            <MenuFlyoutItem Text="Streamable HTTP" Click="FilterTransport_Click" Tag="streamable-http"/>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <Button x:Name="RefreshButton" Click="RefreshButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="刷新"/>
                    </StackPanel>
                </Button>
                <Button x:Name="AddMcpServerButton" Click="AddMcpServer_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="添加服务器"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- MCP Servers 内容区域 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">
                <!-- 状态概览卡片 -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0"
                           CornerRadius="{ThemeResource OverlayCornerRadius}"
                           Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           Padding="16">
                        <StackPanel>
                            <FontIcon Glyph="&#xE774;" FontSize="24" Opacity="0.8"/>
                            <TextBlock x:Name="TotalServersText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock Text="可用服务器" Opacity="0.7"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="1"
                           CornerRadius="{ThemeResource OverlayCornerRadius}"
                           Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           Padding="16">
                        <StackPanel>
                            <FontIcon Glyph="&#xE7AC;" FontSize="24" Opacity="0.8"/>
                            <TextBlock x:Name="ActiveServersText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock Text="活跃状态" Opacity="0.7"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="2"
                           CornerRadius="{ThemeResource OverlayCornerRadius}"
                           Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           Padding="16">
                        <StackPanel>
                            <FontIcon Glyph="&#xE71D;" FontSize="24" Opacity="0.8"/>
                            <TextBlock x:Name="TransportTypesText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock Text="传输类型" Opacity="0.7"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="3"
                           CornerRadius="{ThemeResource OverlayCornerRadius}"
                           Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           Padding="16">
                        <StackPanel>
                            <FontIcon Glyph="&#xE7B8;" FontSize="24" Opacity="0.8"/>
                            <TextBlock x:Name="LastUpdatedText" Text="--" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock Text="最后更新" Opacity="0.7"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 加载状态 -->
                <ProgressBar x:Name="LoadingProgressBar"
                           IsIndeterminate="True"
                           Visibility="Collapsed"
                           Margin="0,10"/>

                <!-- 错误提示 -->
                <InfoBar x:Name="ErrorInfoBar"
                        IsOpen="False"
                        Severity="Error"
                        Title="加载失败"
                        Message="无法从 MCP Registry 获取数据"
                        HorizontalAlignment="Stretch"/>

                <!-- MCP Servers 列表 -->
                <Pivot x:Name="McpPivot">
                    <PivotItem Header="浏览市场">
                        <StackPanel Margin="0,10,0,0">
                            <!-- 分类标签 -->
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                         VerticalScrollBarVisibility="Disabled"
                                         Margin="0,0,0,16">
                                <StackPanel x:Name="CategoryFilterPanel" Orientation="Horizontal" Spacing="8">
                                    <Button Content="全部" 
                                           Style="{StaticResource AccentButtonStyle}"
                                           Click="FilterCategory_Click" Tag=""/>
                                    <Button Content="数据库" Click="FilterCategory_Click" Tag="database"/>
                                    <Button Content="文件系统" Click="FilterCategory_Click" Tag="filesystem"/>
                                    <Button Content="开发工具" Click="FilterCategory_Click" Tag="dev"/>
                                    <Button Content="搜索" Click="FilterCategory_Click" Tag="search"/>
                                    <Button Content="浏览器" Click="FilterCategory_Click" Tag="browser"/>
                                    <Button Content="版本控制" Click="FilterCategory_Click" Tag="git"/>
                                    <Button Content="云服务" Click="FilterCategory_Click" Tag="cloud"/>
                                </StackPanel>
                            </ScrollViewer>
                            
                            <!-- MCP Server 卡片列表 -->
                            <ListView x:Name="McpServersList"
                                     SelectionMode="Single"
                                     IsItemClickEnabled="True"
                                     ItemClick="McpServerItem_Click">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Grid Grid.Column="0" Margin="0,0,16,0">
                                                <FontIcon Glyph="&#xE774;" FontSize="32"/>
                                            </Grid>
                                            
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding DisplayName}"
                                                          FontSize="18"
                                                          FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Description}"
                                                          TextWrapping="Wrap"
                                                          MaxWidth="500"
                                                          Opacity="0.8"
                                                          Margin="0,4,0,0"/>
                                                <StackPanel Orientation="Horizontal" 
                                                           Spacing="12"
                                                           Margin="0,8,0,0">
                                                    <TextBlock Text="{Binding TransportTypeDisplay}"
                                                              FontSize="12"
                                                              Opacity="0.6"/>
                                                    <TextBlock Text="{Binding Version}"
                                                              FontSize="12"
                                                              Opacity="0.6"/>
                                                    <TextBlock Text="{Binding StatusDisplay}"
                                                              FontSize="12">
                                                        <TextBlock.Foreground>
                                                            <SolidColorBrush Color="{Binding StatusColor}"/>
                                                        </TextBlock.Foreground>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <Button Grid.Column="2"
                                                   Content="查看"
                                                    Click="ViewMcpServer_Click"
                                                   VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            
                            <!-- 空状态提示 -->
                            <TextBlock x:Name="EmptyStateText"
                                      Text="暂无数据"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Opacity="0.6"
                                      Margin="0,50"
                                      Visibility="Collapsed"/>
                        </StackPanel>
                    </PivotItem>
                    
                    <PivotItem Header="已配置">
                        <Grid>
                            <TextBlock Text="暂无配置的 MCP Servers"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Opacity="0.6"
                                      Margin="0,50"/>
                        </Grid>
                    </PivotItem>
                    
                    <PivotItem Header="日志">
                        <Border CornerRadius="{ThemeResource OverlayCornerRadius}"
                               Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                               Padding="16"
                               Margin="0,10,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="McpLogsText"
                                          FontFamily="Consolas"
                                          FontSize="12"
                                          Opacity="0.9"
                                          Text="[INFO] MCP 服务初始化中...&#x0A;[INFO] 等待服务器连接..."/>
                            </ScrollViewer>
                        </Border>
                    </PivotItem>
                </Pivot>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
