<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AIReady.Desktop.Pages.SkillsStorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    BorderBrush="Transparent"
    Background="Transparent">

    <Grid Background="Transparent" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Skills 商店"
                      FontSize="32"
                      FontWeight="Bold"
                      Foreground="White"/>
            <TextBlock Text="发现和管理 AI Skills，扩展您的 AI 能力"
                      FontSize="16"
                      Foreground="White"
                      Opacity="0.8"
                      Margin="0,5,0,0"/>
            <HyperlinkButton Content="📖 数据来源: AIReady 内置 + GitHub(anthropics/skills)"
                           NavigateUri="https://github.com/anthropics/skills"
                           Margin="0,5,0,0"
                           Foreground="White"/>
        </StackPanel>

        <!-- 搜索和筛选栏 -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <AutoSuggestBox x:Name="SearchBox"
                           PlaceholderText="搜索 Skills..."
                           QueryIcon="Find"
                           Height="40"
                           VerticalAlignment="Center"
                           QuerySubmitted="SearchBox_QuerySubmitted"/>
            
            <StackPanel Grid.Column="1" 
                       Orientation="Horizontal" 
                       Spacing="10"
                       Margin="20,0,0,0">
                <DropDownButton Content="分类">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="全部" Click="FilterCategory_Click" Tag=""/>
                            <MenuFlyoutItem Text="编程开发" Click="FilterCategory_Click" Tag="编程开发"/>
                            <MenuFlyoutItem Text="内容创作" Click="FilterCategory_Click" Tag="内容创作"/>
                            <MenuFlyoutItem Text="数据分析" Click="FilterCategory_Click" Tag="数据分析"/>
                            <MenuFlyoutItem Text="系统管理" Click="FilterCategory_Click" Tag="系统管理"/>
                            <MenuFlyoutItem Text="设计创意" Click="FilterCategory_Click" Tag="设计创意"/>
                            <MenuFlyoutItem Text="商业办公" Click="FilterCategory_Click" Tag="商业办公"/>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <DropDownButton Content="排序">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="热门" Click="Sort_Click" Tag="popular"/>
                            <MenuFlyoutItem Text="最新" Click="Sort_Click" Tag="newest"/>
                            <MenuFlyoutItem Text="评分" Click="Sort_Click" Tag="rating"/>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <Button x:Name="RefreshButton" Click="RefreshButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="刷新"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 加载状态 -->
        <ProgressBar x:Name="LoadingProgressBar"
                    Grid.Row="2"
                    IsIndeterminate="True"
                    Visibility="Collapsed"
                    Margin="0,10"
                    VerticalAlignment="Top"/>

        <!-- 错误提示 -->
        <InfoBar x:Name="ErrorInfoBar"
                Grid.Row="2"
                IsOpen="False"
                Severity="Error"
                Title="加载失败"
                Message="无法获取 Skills 数据"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Margin="0,40,0,0"/>

        <!-- Skills 列表区域 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 统计信息 -->
                <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,20">
                    <TextBlock x:Name="TotalSkillsText" 
                              Text="0 Skills 可用"
                              Opacity="0.8"/>
                    <TextBlock x:Name="LastUpdatedText"
                              Text=""
                              Opacity="0.6"/>
                </StackPanel>

                <!-- 分类标签 -->
                <Pivot x:Name="SkillsPivot" Margin="0,0,0,20">
                    <PivotItem Header="推荐">
                        <GridView x:Name="FeaturedSkillsGrid"
                                 SelectionMode="None"
                                 IsItemClickEnabled="True"
                                 ItemClick="SkillItem_Click">
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="280" 
                                           Height="200"
                                           CornerRadius="{ThemeResource OverlayCornerRadius}"
                                           Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                           BorderThickness="1">
                                        <Border.Shadow>
                                            <ThemeShadow/>
                                        </Border.Shadow>
                                        <Grid Margin="16">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <StackPanel Orientation="Horizontal" Grid.Row="0">
                                                <FontIcon Glyph="&#xE74C;" FontSize="28"/>
                                                <StackPanel Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding Name}"
                                                              FontWeight="SemiBold"
                                                              TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Author}"
                                                              Opacity="0.7"
                                                              FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Row="1"
                                                      Text="{Binding Description}"
                                                      TextWrapping="Wrap"
                                                      TextTrimming="WordEllipsis"
                                                      Margin="0,8,0,0"
                                                      Opacity="0.8"
                                                      MaxLines="3"/>
                                            
                                            <StackPanel Grid.Row="2" 
                                                       Orientation="Horizontal" 
                                                       Spacing="12"
                                                       Margin="0,8,0,0">
                                                <TextBlock FontSize="12" Opacity="0.6">
                                                    <Run Text="⭐ "/><Run Text="{Binding Rating}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="12" Opacity="0.6">
                                                    <Run Text="📥 "/><Run Text="{Binding InstallCount}"/>
                                                </TextBlock>
                                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                        CornerRadius="{ThemeResource ControlCornerRadius}"
                                                        Padding="6,2">
                                                    <TextBlock Text="{Binding Category}"
                                                              FontSize="11"
                                                              Opacity="0.7"/>
                                                </Border>
                                            </StackPanel>
                                            
                                            <Grid Grid.Row="3" Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                       Content="查看"
                                                       HorizontalAlignment="Stretch"
                                                       Click="ViewSkill_Click"/>
                                                <Button Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       Click="FavoriteSkill_Click">
                                                    <FontIcon Glyph="{Binding FavoriteIcon}"
                                                             FontSize="14"/>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </PivotItem>
                    
                    <PivotItem Header="已安装">
                        <TextBlock Text="暂无已安装的 Skills"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Opacity="0.6"
                                  Margin="0,50"/>
                    </PivotItem>
                    
                    <PivotItem Header="收藏">
                        <TextBlock Text="暂无收藏的 Skills"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Opacity="0.6"
                                  Margin="0,50"/>
                    </PivotItem>
                </Pivot>

                <!-- 开发提示 -->
                <InfoBar IsOpen="True"
                        Severity="Informational"
                        Title="功能开发中"
                        Message="Skills 商店已连接静态数据源。未来将支持从 GitHub anthropics/skills 自动同步。"
                        HorizontalAlignment="Center"
                        Margin="0,20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
