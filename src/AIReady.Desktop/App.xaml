<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="AIReady.Desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AIReady.Desktop"
    xmlns:pages="using:AIReady.Desktop.Pages">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- 自定义亚克力画笔 -->
            <AcrylicBrush x:Key="CustomAcrylicInAppLuminosity"
                         TintOpacity="0" 
                         TintLuminosityOpacity="0" 
                         TintColor="SkyBlue" 
                         FallbackColor="SkyBlue" />
            
            <!-- NavigationView 展开时的亚克力效果 -->
            <AcrylicBrush x:Key="NavigationViewExpandedPaneBackground"
                          TintOpacity="0.7"
                          TintLuminosityOpacity="0.7"
                          TintColor="#202020"
                          FallbackColor="#202020"/>
            
            <!-- 覆盖系统按钮颜色 -->
            <SolidColorBrush x:Key="WindowCaptionForeground" Color="White"/>
            <SolidColorBrush x:Key="WindowCaptionForegroundDisabled" Color="White"/>
            <SolidColorBrush x:Key="WindowCaptionButtonHoverBackgroundBrush" Color="#22FFFFFF"/>
            <SolidColorBrush x:Key="WindowCaptionButtonPressedBackgroundBrush" Color="#44FFFFFF"/>
            
            <!-- NavigationView 相关样式覆盖 -->
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewPaneBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent"/>
            
            <!-- NavigationView Item 样式 -->
            <SolidColorBrush x:Key="NavigationViewItemBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#22FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver" Color="#11FFFFFF"/>
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed" Color="#33FFFFFF"/>
            
            <!-- 布尔值转换器 -->
            <pages:InverseBoolConverter x:Key="InverseBoolConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
