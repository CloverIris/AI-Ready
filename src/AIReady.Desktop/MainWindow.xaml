<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AIRaedy.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AIRaedy.Desktop"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- 背景图片 -->
        <Image Stretch="UniformToFill">
            <Image.Source>
                <BitmapImage UriSource="picture/BackGround.jpg"/>
            </Image.Source>
        </Image>

        <NavigationView x:Name="NavView"
                        Background="Transparent"
                        Opacity="1"
                        PaneDisplayMode="LeftMinimal"
                        IsPaneToggleButtonVisible="True"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        SelectionChanged="NavigationView_SelectionChanged">
            
            <NavigationView.Content>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 自定义标题栏 -->
                    <Rectangle x:Name="AppTitleBar" 
                               Height="48" 
                               Fill="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                               DoubleTapped="AppTitleBar_DoubleTapped" />

                    <!-- 内容框架 -->
                    <Frame x:Name="ContentFrame" 
                           Grid.Row="1"
                           Margin="0,0,0,0"
                           Background="Transparent" />
                </Grid>
            </NavigationView.Content>

            <!-- 导航菜单项 -->
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="HomeItem" 
                                   Icon="Home" 
                                   Content="首页" 
                                   Tag="HomePage"
                                   IsSelected="True"/>
                <NavigationViewItem Icon="Play" Content="本地 AI" Tag="LocalPage"/>
                <NavigationViewItem Icon="Cloud" Content="云端管理" Tag="CloudPage"/>
                <NavigationViewItem Icon="Library" Content="工作流" Tag="WorkflowsPage"/>
            </NavigationView.MenuItems>
            
            <!-- 底部菜单项 -->
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Icon="Help" Content="帮助" Tag="HelpPage"/>
                <NavigationViewItem Icon="Setting" Content="设置" Tag="SettingsPage"/>
            </NavigationView.FooterMenuItems>
            
        </NavigationView>
        
        <!-- 标题文本 -->
        <TextBlock VerticalAlignment="Top" 
                   HorizontalAlignment="Center" 
                   Margin="60,12,0,0" 
                   FontSize="18" 
                   Foreground="White" 
                   Text="AIReady"/>
    </Grid>
</Window>
